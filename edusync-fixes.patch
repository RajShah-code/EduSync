diff --git a/Backend/.env.example b/Backend/.env.example
new file mode 100644
index 0000000..96532c6
--- /dev/null
+++ b/Backend/.env.example
@@ -0,0 +1,16 @@
+# Server
+PORT=3000
+
+# Local Postgres example:
+#   DATABASE_URL=postgresql://postgres:password@localhost:5432/EduSync
+# Neon example (SSL is auto-detected from "neon.tech" in the URL — no extra config needed):
+#   DATABASE_URL=postgresql://<user>:<password>@<your-neon-host>.neon.tech/EduSync?sslmode=require
+DATABASE_URL=postgresql://<YOUR_POSTGRES_USER>:<YOUR_POSTGRES_PASSWORD>@localhost:5432/EduSync
+
+# Set to true to force SSL for a non-Neon remote/cloud DB.
+# Not needed for local Postgres or for Neon (auto-detected above).
+DB_SSL=false
+
+# Auth
+JWT_SECRET=any_random_string_here
+JWT_EXPIRES_IN=7d
diff --git a/Backend/config/db.js b/Backend/config/db.js
index 36681c2..8498ec9 100644
--- a/Backend/config/db.js
+++ b/Backend/config/db.js
@@ -3,8 +3,14 @@ const dotenv = require('dotenv');
 const path = require('path');
 dotenv.config({ path: path.join(__dirname, '../.env') });
 
+// SSL is required by Neon (and most managed Postgres) but unavailable on a
+// bare local install. Auto-detect Neon via the connection string, and allow
+// an explicit DB_SSL=true override for any other remote/cloud DB.
+const isNeon = /neon\.tech/.test(process.env.DATABASE_URL || '');
+const useSSL = process.env.DB_SSL === 'true' || isNeon;
+
 const sql = postgres(process.env.DATABASE_URL, {
-  ssl: false,          // set to true only if using a remote/cloud DB
+  ssl: useSSL ? 'require' : false,
   max: 10,             // max connections in pool
   idle_timeout: 30,
 });
